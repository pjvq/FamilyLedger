# FamilyLedger — Environment Variables
# Copy to .env and fill in production values.

# Database credentials (required)
DB_USER=familyledger
DB_PASSWORD=change-me-in-production

# Database name
DB_NAME=familyledger

# JWT secret (required, ≥32 chars)
JWT_SECRET=change-me-in-production-at-least-32-chars

# OAuth mode: mock (dev) or production (real providers)
OAUTH_MODE=mock

# Allowed WebSocket origins (comma-separated, or * for dev)
# ALLOWED_ORIGINS=https://app.example.com
