# FamilyLedger production environment
# Copy to .env and fill in real values before deployment.
#
# Usage: cp .env.example .env && vim .env

# ─── Required ─────────────────────────────────────────────────
DB_PASSWORD=change-me-in-production
JWT_SECRET=change-me-in-production-at-least-32-chars

# ─── Database ─────────────────────────────────────────────────
# DB_USER=familyledger
# DB_NAME=familyledger
# DB_MAX_CONNS=20
# DB_MIN_CONNS=2

# ─── TLS ──────────────────────────────────────────────────────
TLS_CERT_FILE=/etc/tls/server.pem
TLS_KEY_FILE=/etc/tls/server-key.pem
# Uncomment to enable mTLS (require client certificates):
# TLS_CA_FILE=/etc/tls/ca.pem
# TLS_MIN_VERSION=1.2

# ─── Server ───────────────────────────────────────────────────
# GRPC_PORT=50051
# WS_PORT=8080
# WS_TOKEN_CHECK_INTERVAL=1s
# APP_ENV=production

# ─── Rate Limiting ────────────────────────────────────────────
# AUTH_RATE_RPS=10
# AUTH_RATE_BURST=20

# ─── OAuth ────────────────────────────────────────────────────
# OAUTH_MODE=mock

# ─── Proxy (enable when behind nginx/envoy/cloudflare) ────────
# TRUST_PROXY=true
