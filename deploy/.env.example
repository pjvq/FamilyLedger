# FamilyLedger production environment
# Copy to .env and fill in real values before deployment.

# Required — docker-compose will refuse to start without these:
DB_PASSWORD=change-me-in-production
JWT_SECRET=change-me-in-production-at-least-32-chars

# Optional — defaults are fine for most setups:
# DB_USER=familyledger
# DB_NAME=familyledger

# Connection pool (increase for high concurrency)
# DB_MAX_CONNS=20
# DB_MIN_CONNS=2

# Proxy settings (enable when behind nginx/envoy/cloudflare)
# TRUST_PROXY=true
